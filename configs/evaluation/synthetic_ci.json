{
  "name": "synthetic_ci",
  "description": "Small deterministic evaluation for pull requests and local smoke checks.",
  "ablation": {
    "shapes": ["sphere"],
    "feedback_iterations": [0, 1],
    "feedback_selectors": ["gate", "uncertainty"],
    "num_points": 45,
    "noise_std": 0.03,
    "grid_size": 8,
    "lengthscale": 0.8,
    "variance": 1.0,
    "image_size": 32,
    "num_splats": 55,
    "epsilon": 0.11,
    "view": "front",
    "seed": 7,
    "feedback_pseudo_points": 6,
    "feedback_min_gate": 0.0
  },
  "targets": {
    "max_rmse_sdf": 0.6,
    "min_iou_inside": 0.2,
    "min_psnr_gpis": 5.0
  },
  "expected_artifacts": [
    "evaluation_config.json",
    "evaluation_checks.csv",
    "evaluation_status.json",
    "evaluation_report.md",
    "summary/ablation_summary.csv",
    "summary/ablation_winners.csv"
  ]
}
